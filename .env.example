# ==============================================================================
# CONFIGURACIÓN DE BASE DE DATOS (POSTGRESQL + POSTGIS)
# ==============================================================================
# NOTA: Para desarrollo local con docker-compose, DB_HOST debe ser 'db'.
# Para scripts corriendo nativamente en tu host, usa 'localhost'.
DB_USER=postgres
DB_PASSWORD=postgres_secure_pass
DB_HOST=db
DB_PORT=5432
DB_NAME=rastreador_db

# ==============================================================================
# CONFIGURACIÓN DEL BACKEND API (FASTAPI)
# ==============================================================================
API_PORT=8000
API_HOST=0.0.0.0

# ==============================================================================
# CONFIGURACIÓN DEL FRONTEND (NEXT.JS)
# ==============================================================================
# URL pública del backend API (usada por useSWR en el cliente)
# Para desarrollo local: http://localhost:8000
# Para Docker: http://localhost:8000 (el frontend accede desde el browser del usuario)
NEXT_PUBLIC_API_URL=http://localhost:8000
PORT=3000
